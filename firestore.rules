rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Restaurants - anyone can read, only admin can write
    match /restaurants/{restaurantId} {
      allow read: if true;
      allow write: if true; // Change to: if request.auth != null && isAdmin(request.auth.uid)
    }

    // Menu items - anyone can read, only admin/restaurant owner can write
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if true; // Change to: if request.auth != null
    }

    // Orders - authenticated users can create, admin/restaurant can update
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true; // Change to: if request.auth != null
    }

    // Riders - anyone can read, only admin can write
    match /riders/{riderId} {
      allow read: if true;
      allow write: if true; // Change to: if request.auth != null && isAdmin(request.auth.uid)
    }

    // Users - users can read/write their own data
    match /users/{userId} {
      allow read: if true;
      allow write: if true; // Change to: if request.auth != null && request.auth.uid == userId
    }
  }
}
